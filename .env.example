NODE_ENV=development
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=*

# Set REDIS_URL in shared or production environments to enable horizontal scaling.
# REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=orbital-estates
GAME_TTL_SECONDS=86400
TRUST_PROXY=false

# Used by the Expo app build to configure the realtime server URL.
EXPO_PUBLIC_SERVER_URL=http://localhost:3000
